__pycache__/
*.pyc
*.pyo
venv/
.env
static/uploads/
*.log
curl.txt
google_vision_key.json
*.dump
service-account*.json
*-credentials.json

# Session secrets — do NOT commit
state/

# Pre-patch backups (timestamped)
*.bak.*

# Local pull/scratch dirs
_backups/
_patches/

# Older backup naming variants (added 2026-05-08 baseline checkpoint)
*.GOOD.*
*.brokenstate.*
*.bak_*
*.bak-*

# Binary runtime artifacts — files rotate, should not be tracked
thumb_cache/
accutrade_reports/
vauto_reports/
ipacket_reports/
private_reports/

# ML model weights + metadata — regenerated nightly by train_per_make.py
# at 04:30 ET from the lsl_training Postgres table (which is backed up via
# the nightly pg_dump). Snapshotting daily retrain output in git creates
# constant noise with no recovery benefit; re-running the trainer reproduces
# them from the source-of-truth training data.
ml/models/per_make/*.json
ml/models_v2/per_make/*.json
ml/models_hybrid/per_make/*.json
ml/models_hybrid_v2/per_make/*.json
